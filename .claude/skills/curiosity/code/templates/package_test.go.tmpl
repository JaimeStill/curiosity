func Test{{Type}}_Basic(t *testing.T) {
	cases := []struct {
		name string
		in   {{InputType}}
		want {{WantType}}
	}{
		{
			name: "basic case",
			in:   {{InputType}}{},
			want: {{WantType}}{},
		},
	}

	for _, tc := range cases {
		t.Run(tc.name, func(t *testing.T) {
			got := {{PACKAGE}}.{{FunctionUnderTest}}(tc.in)
			if got != tc.want {
				t.Errorf("got %v, want %v", got, tc.want)
			}
		})
	}
}

